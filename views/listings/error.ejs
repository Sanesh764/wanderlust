<% layout("layouts/boilerplate") %>

<div class="row mt-3">
  <div class="col-8 offset-2">
    <div class="alert alert-danger" role="alert">
      <h4 class="alert-heading">Error <%= err.statusCode || 500 %></h4>
      <hr>
      <p class="mb-0"><%= err.message || "Something went wrong!" %></p>
    </div>
    <a href="/listings" class="btn btn-primary">Back to All Listings</a>
  </div>
</div>