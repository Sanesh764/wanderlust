<% layout("layouts/boilerplate") %>

<div class="row">
  <div class="col-12 details-header">
    <h1><%= listing.title %></h1>
    <div class="details-meta">
      <span><i class="fa-solid fa-star" style="color: #ffb100;"></i> <%= listing.reviews && listing.reviews.length > 0 ? listing.reviews.length + " reviews" : "New" %></span>
      <span class="meta-dot">·</span>
      <span><i class="fa-solid fa-location-dot"></i> <%= listing.location %>, <%= listing.country %></span>
    </div>
  </div>

  <div class="col-12 details-gallery">
    <% if(listing.image && listing.image.url) { %>
      <img src="<%= listing.image.url %>" class="img-fluid" alt="<%= listing.title %>">
    <% } else { %>
      <img src="https://images.unsplash.com/photo-1571896349842-33c89424de2d?ixlib=rb-4.0.3&auto=format&fit=crop&w=1200&q=80" class="img-fluid" alt="default property image">
    <% } %>
  </div>
</div>

<div class="show-layout">
  <!-- Left Side: Property details and reviews -->
  <div class="info-content">
    <div class="host-section">
      <div class="host-info">
        <% if(listing.owner && listing.owner.username) { %>
          <h2>Hosted by <%= listing.owner.username %></h2>
          <p>Superhost · 2 years hosting experience</p>
        <% } else { %>
          <h2>Hosted by Wanderlust Host</h2>
          <p>Verified Partner Host</p>
        <% } %>
      </div>
      <div class="host-avatar-circle">
        <%= listing.owner && listing.owner.username ? listing.owner.username[0].toUpperCase() : "W" %>
      </div>
    </div>

    <div class="description-section">
      <h3 class="h5 font-weight-bold mb-3">About this place</h3>
      <p><%= listing.description %></p>
    </div>

    <!-- Mock Amenities Section to make UI look premium -->
    <div class="amenities-container">
      <h3>What this place offers</h3>
      <div class="amenity-grid-list">
        <div class="amenity-card-item">
          <i class="fa-solid fa-wifi"></i>
          <span>Fast wifi (50 Mbps)</span>
        </div>
        <div class="amenity-card-item">
          <i class="fa-solid fa-square-parking"></i>
          <span>Free parking on premises</span>
        </div>
        <div class="amenity-card-item">
          <i class="fa-solid fa-snowflake"></i>
          <span>Air conditioning</span>
        </div>
        <div class="amenity-card-item">
          <i class="fa-solid fa-tv"></i>
          <span>HD TV with Netflix</span>
        </div>
        <div class="amenity-card-item">
          <i class="fa-solid fa-kitchen-set"></i>
          <span>Kitchen access</span>
        </div>
        <div class="amenity-card-item">
          <i class="fa-solid fa-paw"></i>
          <span>Pets allowed</span>
        </div>
      </div>
    </div>

    <!-- Review Section -->
    <div class="reviews-container">
      <% if(currUser) { %>
        <div class="review-form-card">
          <h4>Leave a Review</h4>
          <form action="/listings/<%=listing.id%>/reviews" method="POST" novalidate class="needs-validation">
            <div class="mb-3">
              <label class="form-label d-block">Rating</label>
              <fieldset class="starability-slot">
                <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1" checked aria-label="No rating." />
                <input type="radio" id="first-rate1" name="review[rating]" value="1" />
                <label for="first-rate1" title="Terrible">1 star</label>
                <input type="radio" id="first-rate2" name="review[rating]" value="2" />
                <label for="first-rate2" title="Not good">2 stars</label>
                <input type="radio" id="first-rate3" name="review[rating]" value="3" />
                <label for="first-rate3" title="Average">3 stars</label>
                <input type="radio" id="first-rate4" name="review[rating]" value="4" />
                <label for="first-rate4" title="Very good">4 stars</label>
                <input type="radio" id="first-rate5" name="review[rating]" value="5" />
                <label for="first-rate5" title="Amazing">5 stars</label>
              </fieldset>
            </div>

            <div class="mb-3">
              <label for="comment" class="form-label">Review Comment</label>
              <textarea name="review[comment]" id="comment" cols="30" rows="4" class="form-control" placeholder="Share your experience staying here..." required></textarea>
              <div class="invalid-feedback">
                Please write a short comment to submit your review.
              </div>
            </div>
            <button class="btn btn-primary-airbnb px-4">Submit Review</button>
          </form>
        </div>
      <% } else { %>
        <div class="alert alert-light border text-center p-3 mb-4" role="alert">
          <i class="fa-solid fa-lock text-muted mr-1"></i> You must be <a href="/login" class="font-weight-bold alert-link text-underline">logged in</a> to write a review.
        </div>
      <% } %>

      <!-- Reviews Listing -->
      <% if(listing.reviews && listing.reviews.length > 0) { %>
        <h3>All Reviews</h3>
        <div class="reviews-grid-list">
          <% for(review of listing.reviews) { %>
            <div class="review-modern-card">
              <div>
                <div class="review-user-block">
                  <div class="user-avatar-circle">
                    <%= review.author && review.author.username ? review.author.username[0].toUpperCase() : "G" %>
                  </div>
                  <div>
                    <h5 class="review-user-name">@<%= review.author && review.author.username ? review.author.username : "Guest" %></h5>
                    <p class="review-date-info">
                      <%= new Date(review.createdAt).toLocaleDateString("en-US", { year: 'numeric', month: 'long', day: 'numeric' }) %>
                    </p>
                  </div>
                </div>

                <div class="review-rating-line">
                  <p class="starability-result" data-rating="<%= review.rating %>">
                    Rated: <%= review.rating %> stars
                  </p>
                </div>

                <p class="review-comment-text">"<%= review.comment %>"</p>
              </div>

              <!-- Owner Authorization Button visibility checks -->
              <% if(currUser && review.author && currUser._id.equals(review.author._id)) { %>
                <form class="review-delete-form" method="POST" action="/listings/<%=listing._id%>/reviews/<%=review._id%>?_method=DELETE">
                  <button class="btn btn-sm btn-outline-danger review-delete-btn">
                    <i class="fa-solid fa-trash-can"></i> Delete
                  </button>
                </form>
              <% } %>
            </div>
          <% } %>
        </div>
      <% } else { %>
        <div class="empty-state-card py-4 my-2">
          <div class="empty-state-icon" style="font-size: 30px; margin-bottom: 8px;">
            <i class="fa-regular fa-comments"></i>
          </div>
          <h4 class="h6 font-weight-bold">No Reviews Yet</h4>
          <p class="small text-muted mb-0">Be the first to share your thoughts about this listing!</p>
        </div>
      <% } %>
    </div>

    <!-- Map Section -->
    <div class="location-section mt-4">
      <h3>Where you'll be</h3>
      <div class="map-container">
        <div id="map" style="height: 380px;"></div>
      </div>
    </div>
  </div>

  <!-- Right Side: Booking / Actions Sticky Widget -->
  <div class="booking-widget-wrapper">
    <div class="booking-widget">
      <div class="booking-header">
        <div>
          <span class="price">₹<%= listing.price.toLocaleString("en-IN") %></span>
          <span class="unit">/ night</span>
        </div>
        <div class="small text-muted font-weight-bold">
          <i class="fa-solid fa-star" style="color: #ffb100;"></i> <%= listing.reviews && listing.reviews.length > 0 ? listing.reviews.length + " reviews" : "New" %>
        </div>
      </div>

      <div class="action-buttons-box">
        <% if(currUser && listing.owner && currUser._id.equals(listing.owner._id)) { %>
          <div class="alert alert-info py-2 px-3 small mb-2 text-center">
            You own this property listing.
          </div>
          <a href="/listings/<%= listing._id %>/edit" class="btn btn-primary-airbnb">
            <i class="fa-solid fa-pen-to-square"></i> Edit Listing
          </a>
          <form method="POST" action="/listings/<%= listing._id %>?_method=DELETE" class="m-0" onsubmit="return confirm('Are you sure you want to delete this listing permanently?');">
            <button type="submit" class="btn btn-outline-danger w-100 py-2.5">
              <i class="fa-solid fa-trash-can"></i> Delete Listing
            </button>
          </form>
        <% } else { %>
          <button type="button" class="btn btn-primary-airbnb" onclick="alert('Booking functionality coming soon!');">
            Reserve Listing
          </button>
          <button type="button" class="btn btn-outline-airbnb" onclick="alert('Host contact functionality coming soon!');">
            Contact Host
          </button>
        <% } %>
      </div>

      <div class="border-top mt-3 pt-3 small text-muted text-center">
        <i class="fa-solid fa-shield-halved text-success"></i> Wanderlust Protection · Safety Guarantee
      </div>
    </div>
  </div>
</div>

<!-- Set Mapbox Access Token -->
<script>
  mapboxgl.accessToken = "<%=process.env.MAP_TOKEN%>";
</script>

<!-- Load map.js -->
<script src="/js/map.js"></script>