<% layout("layouts/boilerplate") %>
<div class="row row-cols-lg-4 row-cols-md-3 row-cols-sm-2 row-cols-1 g-4 listings-grid">
  <% if (allListings && allListings.length > 0) { %>
    <% for(let listing of allListings) { %>
      <div class="col">
        <a href="/listings/<%=listing._id%>" class="listing-card-link">
          <div class="listing-card-wrapper">
            <div class="card-img-container">
              <% if(listing.image && listing.image.url) { %>
                <img src="<%=listing.image.url%>" alt="<%= listing.title %>" loading="lazy">
              <% } else { %>
                <img src="https://images.unsplash.com/photo-1571896349842-33c89424de2d?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=60" alt="default listing image" loading="lazy">
              <% } %>
              
              <!-- Heart icon for favorites -->
              <button type="button" class="favorite-heart-btn" aria-label="Add to favorites" onclick="event.preventDefault(); this.classList.toggle('active');">
                <i class="fa-regular fa-heart"></i>
              </button>
              
              <!-- Price badge -->
              <div class="listing-price-badge">
                ₹<%= listing.price.toLocaleString("en-IN") %>/night
              </div>
            </div>
            
            <div class="card-info">
              <div class="card-title-row">
                <h4><%= listing.title %></h4>
                <div class="card-rating">
                  <i class="fa-solid fa-star"></i>
                  <span><%= listing.reviews && listing.reviews.length > 0 ? listing.reviews.length : "New" %></span>
                </div>
              </div>
              <div class="card-location">
                <i class="fa-solid fa-location-dot" style="font-size: 11px; margin-right: 2px;"></i> <%= listing.location %>, <%= listing.country %>
              </div>
            </div>
          </div>
        </a>
      </div>
    <% } %>
  <% } else { %>
    <div class="col-12">
      <div class="empty-state-card w-100">
        <div class="empty-state-icon">
          <i class="fa-solid fa-circle-question"></i>
        </div>
        <h3>No properties found</h3>
        <p>No listings match your search criteria. Try removing some filters or search for another destination.</p>
        <a href="/listings" class="btn btn-primary-airbnb px-4">View All Properties</a>
      </div>
    </div>
  <% } %>
</div>
