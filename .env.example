# =========================================================================
# Wanderlust (Airbnb Clone) - Environment Variables Configuration Template
# Copy this file to a new file named '.env' and populate with your own keys.
# =========================================================================

# --- SERVER CONFIGURATION ---
# The port number on which the Express server will listen. (Default: 3000)
PORT=3000

# The environment mode: 'development' or 'production'.
# In development, detailed error stacks are displayed; in production, they are hidden.
NODE_ENV=development

# --- DATABASE CONFIGURATION ---
# MongoDB Connection URI. 
# For local database testing, use: mongodb://127.0.0.1:27017/wanderlust
# For MongoDB Atlas cloud database, use: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>
MONGO_URL=mongodb://127.0.0.1:27017/wanderlust

# --- SECURITY & SESSIONS ---
# A secure, random string secret used to sign session cookies.
SECRET=yoursecretkeyhere

# --- CLOUDINARY CONFIGURATION (Image Uploads) ---
# Your Cloudinary credentials for handling file/image uploads for listings.
# Found in the Cloudinary dashboard: https://console.cloudinary.com/
CLOUD_NAME=your_cloudinary_cloud_name
CLOUD_API_KEY=your_cloudinary_api_key
CLOUD_API_SECRET=your_cloudinary_api_secret

# --- GEOLOCATION CONFIGURATION (Maps) ---
# Mapbox public access token for rendering interactive maps.
# Sign up at Mapbox to get a token: https://www.mapbox.com/
MAP_TOKEN=your_mapbox_public_access_token